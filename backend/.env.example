NODE_ENV=development
PORT=4000

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bengo
POSTGRES_SYNC=true

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# data.go.kr
DATA_GO_KR_API_KEY=
DATA_GO_KR_API_URL=
DATA_GO_KR_API_KEY_PARAM=serviceKey
DATA_GO_KR_PAGE_PARAM=page
DATA_GO_KR_PAGE_SIZE_PARAM=perPage
DATA_GO_KR_PAGE_SIZE=100
DATA_GO_KR_MAX_PAGES=20

# 온통청년 청년정책
YOUTHCENTER_POLICY_API_KEY=
YOUTHCENTER_POLICY_API_URL=https://www.youthcenter.go.kr/go/ythip/getPlcy
YOUTHCENTER_POLICY_API_KEY_PARAM=apiKeyNm
YOUTHCENTER_POLICY_PAGE_PARAM=pageNum
YOUTHCENTER_POLICY_PAGE_SIZE_PARAM=pageSize
YOUTHCENTER_POLICY_PAGE_TYPE_PARAM=pageType
YOUTHCENTER_POLICY_PAGE_TYPE=1
YOUTHCENTER_POLICY_RETURN_TYPE_PARAM=rtnType
YOUTHCENTER_POLICY_RETURN_TYPE=json
YOUTHCENTER_POLICY_PAGE_SIZE=100
YOUTHCENTER_POLICY_MAX_PAGES=30
YOUTHCENTER_POLICY_REGION_PARAM=zipCd
YOUTHCENTER_POLICY_REGION_VALUE=11000

# 온통청년 청년센터
YOUTHCENTER_CENTER_API_KEY=
YOUTHCENTER_CENTER_API_URL=https://www.youthcenter.go.kr/go/ythip/getSpace
YOUTHCENTER_CENTER_API_KEY_PARAM=apiKeyNm
YOUTHCENTER_CENTER_PAGE_PARAM=pageNum
YOUTHCENTER_CENTER_PAGE_SIZE_PARAM=pageSize
YOUTHCENTER_CENTER_PAGE_TYPE_PARAM=pageType
YOUTHCENTER_CENTER_PAGE_TYPE=1
YOUTHCENTER_CENTER_RETURN_TYPE_PARAM=rtnType
YOUTHCENTER_CENTER_RETURN_TYPE=json
YOUTHCENTER_CENTER_PAGE_SIZE=100

# 서울 열린데이터광장
SEOUL_OPEN_API_KEY=
SEOUL_OPEN_API_URL=
SEOUL_OPEN_API_KEY_PARAM=KEY
SEOUL_OPEN_API_HOST=http://openapi.seoul.go.kr:8088
SEOUL_OPEN_API_FORMAT=json
SEOUL_OPEN_API_SERVICE_NAME=
SEOUL_OPEN_API_SERVICE_NAMES=
SEOUL_OPEN_API_START_INDEX=1
SEOUL_OPEN_API_END_INDEX=100
SEOUL_OPEN_API_PAGE_SIZE=100
SEOUL_OPEN_API_MAX_PAGES=30
