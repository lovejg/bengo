# ─────────────────────────────────────────────────────────────
# Bengo 백엔드 환경 변수 예시
# 실제 값을 채워 `.env` 로 복사해서 사용하세요. (`.env` 는 커밋되지 않습니다)
# ─────────────────────────────────────────────────────────────

# 앱
NODE_ENV=development
PORT=4000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=bengo
POSTGRES_SYNC=false   # 프로덕션에서는 반드시 false (마이그레이션 사용)

# Redis (정책 목록 캐시)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# 인증 (JWT)
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ── 정책 수집 소스 ────────────────────────────────────────────
# data.go.kr (정부24)
DATA_GO_KR_API_URL=https://api.odcloud.kr/api/gov24/v3/serviceList
DATA_GO_KR_DETAIL_API_URL=https://api.odcloud.kr/api/gov24/v3/serviceDetail
DATA_GO_KR_CONDITIONS_API_URL=https://api.odcloud.kr/api/gov24/v3/supportConditions
DATA_GO_KR_API_KEY=
DATA_GO_KR_API_KEY_PARAM=serviceKey
DATA_GO_KR_PAGE_PARAM=page
DATA_GO_KR_PAGE_SIZE_PARAM=perPage
DATA_GO_KR_PAGE_SIZE=100
DATA_GO_KR_MAX_PAGES=30
DATA_GO_KR_FILTER_KEYWORDS=청년,육아,아동,노인,어르신,장애인
DATA_GO_KR_FILTER_FIELD=서비스명

# 온통청년 (youthcenter)
YOUTHCENTER_POLICY_API_URL=https://www.youthcenter.go.kr/go/ythip/getPlcy
YOUTHCENTER_POLICY_API_KEY=
YOUTHCENTER_POLICY_API_KEY_PARAM=apiKeyNm
YOUTHCENTER_POLICY_PAGE_PARAM=pageNum
YOUTHCENTER_POLICY_PAGE_SIZE_PARAM=pageSize
YOUTHCENTER_POLICY_PAGE_TYPE_PARAM=pageType
YOUTHCENTER_POLICY_PAGE_TYPE=1
YOUTHCENTER_POLICY_RETURN_TYPE_PARAM=rtnType
YOUTHCENTER_POLICY_RETURN_TYPE=json
YOUTHCENTER_POLICY_PAGE_SIZE=100
YOUTHCENTER_POLICY_MAX_PAGES=50
YOUTHCENTER_POLICY_REGION_PARAM=zipCd
YOUTHCENTER_POLICY_REGION_VALUE=11000

# 서울 열린데이터광장
SEOUL_OPEN_API_KEY=
SEOUL_OPEN_API_SERVICE_NAMES=jobNewDealBizOpenInfo,jobCafeOpenInfo,pjMg,GetJobInfo
SEOUL_OPEN_API_PAGE_SIZE=100
SEOUL_OPEN_API_MAX_PAGES=30

# 복지로 (data.go.kr 사회보장정보)
BOKJIRO_API_KEY=
BOKJIRO_CENTRAL_API_URL=https://apis.data.go.kr/B554287/NationalWelfareInformationsV001/NationalWelfarelistV001
BOKJIRO_LOCAL_API_URL=https://apis.data.go.kr/B554287/LocalGovernmentWelfareInformations/LcgvWelfarelist
BOKJIRO_CENTRAL_DETAIL_API_URL=https://apis.data.go.kr/B554287/NationalWelfareInformationsV001/NationalWelfaredetailedV001
BOKJIRO_LOCAL_DETAIL_API_URL=https://apis.data.go.kr/B554287/LocalGovernmentWelfareInformations/LcgvWelfaredetailed
BOKJIRO_LOCAL_CTPV_NMS=서울특별시
BOKJIRO_PAGE_SIZE=100
BOKJIRO_MAX_PAGES=30

# ── LLM (정책 자격조건 추출, Anthropic) ──────────────────────
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001
LLM_ENABLED=false   # true 로 두면 수집 시 LLM 규칙 추출을 수행

# ── 소셜 로그인 (OAuth) ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_CALLBACK_URL=http://localhost:4000/auth/naver/callback
FRONTEND_OAUTH_REDIRECT_URL=http://localhost:5173/oauth/callback

# ── 이메일 인증 (SMTP) ────────────────────────────────────────
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Bengo <no-reply@example.com>"

# ── 베이스 URL ────────────────────────────────────────────────
BACKEND_BASE_URL=http://localhost:4000
FRONTEND_BASE_URL=http://localhost:5173
